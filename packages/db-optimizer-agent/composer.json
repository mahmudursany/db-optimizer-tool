{
  "name": "mdj/db-optimizer-agent",
  "description": "Laravel DB query optimizer agent and scanner dashboard for local/staging.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0",
    "illuminate/database": "^10.0|^11.0",
    "illuminate/http": "^10.0|^11.0",
    "illuminate/routing": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Mdj\\DbOptimizer\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Mdj\\DbOptimizer\\Providers\\DbOptimizerServiceProvider"
      ]
    }
  }
}
